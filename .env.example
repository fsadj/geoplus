# GEO+ Competition Project — Required Environment Variables
#
# Copy this file to .env (do NOT commit .env to git):
#   cp .env.example .env
#
# All API keys and auth tokens must be set via environment.
# Source code does NOT contain any default credentials.

# --- Model API (required) ---
# DeepSeek / Anthropic-compatible API
export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
export ANTHROPIC_AUTH_TOKEN="your-api-token-here"
export ANTHROPIC_MODEL="deepseek-v4-flash"

# --- Bocha Web Search API (required for reference pool step) ---
export BOCHA_API_KEY="your-bocha-api-key-here"

# --- Simulator overrides (optional) ---
export SIMULATOR_BASE_URL=""
export SIMULATOR_AUTH_TOKEN=""
export SIMULATOR_ANSWER_MODEL=""
export SIMULATOR_JUDGE_MODEL=""
